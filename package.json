{
  "name": "fullstack_assignment",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx scripts/seed.ts",
    "typecheck": "tsc --noEmit",
    "docker:dev": "docker compose -f docker/docker-compose.dev.yml up -d",
    "docker:build": "docker compose -f docker/docker-compose.yml build",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:observability": "docker compose -f docker/docker-compose.observability.yml up -d",
    "docker:observability:stop": "docker compose -f docker/docker-compose.observability.yml down",
    "docker:all": "docker compose -f docker/docker-compose.dev.yml -f docker/docker-compose.observability.yml up -d",
    "docker:openreplay": "docker compose -f docker/docker-compose.openreplay.yml up -d",
    "metrics": "curl -s http://localhost:3000/api/metrics | head -50",
    "analyze": "next build && next experimental-analyze",
    "analyze:output": "next build && next experimental-analyze --output",
    "lighthouse": "npx lhci autorun",
    "prepare": "node -e \"try { require('child_process').execSync('husky', { stdio: 'inherit' }) } catch { }\""
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/lib-storage": "^3.1053.0",
    "@better-auth/drizzle-adapter": "^1.6.11",
    "@casl/ability": "^7.0.0",
    "@clerk/nextjs": "^7.4.2",
    "@hookform/resolvers": "^5.4.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/instrumentation-http": "^0.218.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@sentry/nextjs": "^10.53.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "better-auth": "^1.6.11",
    "bullmq": "^5.77.2",
    "date-fns": "^4.2.1",
    "drizzle-orm": "^0.45.2",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.4",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "typesense": "^3.0.6",
    "uuid": "^14.0.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/helmet": "^0.0.48",
    "@types/node": "^20.19.41",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "optionalDependencies": {
    "redis": "^5.12.1"
  }
}
