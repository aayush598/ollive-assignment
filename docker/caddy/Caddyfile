# LLM Inference Logger - Caddy Reverse Proxy Configuration
# Security headers are set by the Next.js app middleware (proxy.ts)
# Caddy handles TLS termination, compression, and routing.
# For production deployment, replace .localhost with real domain names
# to get auto-HTTPS via Let's Encrypt.

http://app.localhost {
    reverse_proxy app:3000 {
        header_up Host {host}
    }

    encode gzip

    @static {
        path /_next/static/* /static/* /favicon.ico /robots.txt /sitemap.xml /manifest.json /sw.js /icons/*
    }
    header @static Cache-Control "public, max-age=31536000, immutable"
}

http://grafana.localhost {
    reverse_proxy grafana:3000
    encode gzip
}

http://prometheus.localhost {
    reverse_proxy prometheus:9090
}

http://loki.localhost {
    reverse_proxy loki:3100
}

http://uptime.localhost {
    reverse_proxy uptime-kuma:3001
}

http://glitchtip.localhost {
    reverse_proxy glitchtip:8000
}

http://umami.localhost {
    reverse_proxy umami:3000
}
